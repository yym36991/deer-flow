
ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONIOENCODING=utf-8 \
    UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple \
    DEER_FLOW_PROJECT_ROOT=/opt/deer-flow \
    DEER_FLOW_HOME=/opt/deer-flow/data/.deer-flow \
    DEER_FLOW_CONFIG_PATH=/opt/deer-flow/config.deploy.yaml \
    DEER_FLOW_EXTENSIONS_CONFIG_PATH=/opt/deer-flow/extensions_config.json \
    DEER_FLOW_CHANNELS_LANGGRAPH_URL=http://127.0.0.1:8001/api \
    DEER_FLOW_CHANNELS_GATEWAY_URL=http://127.0.0.1:8001 \
    DEER_FLOW_INTERNAL_AUTH_TOKEN=deerflow-58-internal \
    DEER_FLOW_LOG_DIR=/opt/deer-flow/logs \
    GATEWAY_WORKERS=1 \
    PYTHONPATH=/opt/deer-flow/backend

RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple uv

RUN mkdir -p /opt/deer-flow/data/.deer-flow /opt/deer-flow/logs && touch /opt/deer-flow/logs/.gitkeep

EXPOSE 8001

ENTRYPOINT []
CMD ["sh", "-c", "echo deerflow-env-image-ready && sleep infinity"]
